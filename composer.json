{
    "name": "baqarrizv/student",
    "description": "Reusable Student Module for Laravel",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "student",
        "module",
        "package"
    ],
    "homepage": "https://github.com/baqarrizv/student",
    "authors": [
        {
            "name": "baqarrizv",
            "email": "baqarrizvi72@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Student\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Student\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Student\\Providers\\StudentServiceProvider"
            ],
            "aliases": {}
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
